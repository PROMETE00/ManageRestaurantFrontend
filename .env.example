# Cloudflare Tunnel Token para Frontend
# Obtén tu token desde: https://dash.cloudflare.com (Zero Trust > Networks > Tunnels)
CLOUDFLARED_TOKEN_FRONTEND=your_token_here

# URL pública de tu API (Backend)
# Después de configurar el túnel, usa: https://restaurantebackend.prome.works
PUBLIC_API_URL=https://restaurantebackend.prome.works
